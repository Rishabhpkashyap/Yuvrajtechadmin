# ============================================
# Yuvraj Tech ADMIN PANEL - ENVIRONMENT VARIABLES
# ============================================

# Firebase Client Configuration (Public - for frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin SDK Configuration (Private - for backend)
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id

# Alternative: Base64 Encoded Service Account (Optional - use this OR individual variables above)
# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=your_base64_encoded_service_account_json_here

# Alternative: Direct JSON Service Account (Optional - use this OR individual variables above)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id",...}

# JWT Secret for Authentication (Generate a secure random string)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# Admin Credentials (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecurePassword123!

# Node Environment
NODE_ENV=development

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 
# 1. FIREBASE SETUP:
#    - Go to Firebase Console: https://console.firebase.google.com/
#    - Create a new project or select existing project
#    - Enable Realtime Database in "Build" section
#    - Set database rules to authenticated access
#
# 2. GET FIREBASE CLIENT CONFIG:
#    - Go to Project Settings (gear icon) > General tab
#    - Scroll to "Your apps" section
#    - Click "Add app" or select existing web app
#    - Copy the config values to NEXT_PUBLIC_FIREBASE_* variables
#
# 3. GET FIREBASE ADMIN SDK CREDENTIALS:
#    - Go to Project Settings > Service Accounts tab
#    - Click "Generate new private key" button
#    - Download the JSON file
#    - Copy values from JSON to FIREBASE_* variables:
#      * project_id → FIREBASE_PROJECT_ID
#      * private_key_id → FIREBASE_PRIVATE_KEY_ID
#      * private_key → FIREBASE_PRIVATE_KEY (keep the quotes and \n)
#      * client_email → FIREBASE_CLIENT_EMAIL
#      * client_id → FIREBASE_CLIENT_ID
#
# 4. GENERATE JWT SECRET:
#    Run this command in terminal:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    Copy the output to JWT_SECRET
#
# 5. SET ADMIN CREDENTIALS:
#    - Change ADMIN_USERNAME if desired
#    - Set a strong ADMIN_PASSWORD (min 8 chars, include special chars)
#
# 6. FIREBASE AUTHENTICATION SETUP:
#    - Go to Firebase Console > Authentication
#    - Click "Get Started"
#    - Enable "Email/Password" sign-in method
#    - Add your admin user manually or use setup script
#
# 7. FIREBASE DATABASE RULES:
#    Set these rules in Realtime Database > Rules:
#    {
#      "rules": {
#        "licenses": {
#          ".read": "auth != null",
#          ".write": "auth != null"
#        }
#      }
#    }
#
# 8. SECURITY:
#    - Copy this file to .env: cp .env.example .env
#    - Fill in all the values in .env
#    - NEVER commit .env file to git
#    - Keep .env.example with placeholder values only
#    - Add .env to .gitignore (should already be there)
#
# 9. INSTALL DEPENDENCIES:
#    npm install
#
# 10. RUN DEVELOPMENT SERVER:
#     npm run dev
#
# ============================================
